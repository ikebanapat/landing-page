---
export type SocialName = "Spotify" | "Instagram" | "YouTube" | "BeatStars" | "SoundCloud";

type SocialLink = {
  name: SocialName;
  url: string;
};

interface Props {
  /** Optional wrapper classes (e.g. reveal/spacing/alignment). */
  class?: string;
  /** Optional override for the links list. */
  links?: SocialLink[];
}

const defaultLinks: SocialLink[] = [
  {
    name: "Spotify",
    url: "https://open.spotify.com/artist/6ENgRzOl5lyD4HavapJ99W?si=K2g0byURTCiOBw9frxmSpQ",
  },
  {
    name: "Instagram",
    url: "https://www.instagram.com/ikebanapat",
  },
  {
    name: "YouTube",
    url: "https://www.youtube.com/@IKEBANAPAT",
  },
];

const { class: className = "", links = defaultLinks } = Astro.props;
const wrapperClass = `flex gap-3 ${className}`.trim();
---

<div class={wrapperClass}>
  {links.map((social) => (
    <a
      href={social.url}
      class="w-10 h-10 rounded-full bg-[var(--card)] border border-[var(--border)] flex items-center justify-center hover:border-[var(--accent)] hover:text-[var(--accent)] transition-all"
      aria-label={social.name}
      title={social.name}
      target="_blank"
      rel="noopener noreferrer"
    >
      {social.name === "Spotify" && (
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/>
        </svg>
      )}
      {social.name === "Instagram" && (
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5"></rect>
          <circle cx="12" cy="12" r="4"></circle>
          <circle cx="18" cy="6" r="1.5" fill="currentColor" stroke="none"></circle>
        </svg>
      )}
      {social.name === "YouTube" && (
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
        </svg>
      )}
      {social.name === "BeatStars" && (
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2L9.19 8.63 2 9.24l5.46 4.73L5.82 21 12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2z"/>
        </svg>
      )}
      {social.name === "SoundCloud" && (
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M1.175 12.225c-.051 0-.094.046-.101.1l-.233 2.154.233 2.105c.007.058.05.098.101.098.05 0 .09-.04.099-.098l.255-2.105-.27-2.154c-.009-.06-.052-.1-.084-.1zm-.899 1.624c-.059 0-.074.025-.082.055l-.193 1.228.193 1.193c.008.033.023.055.066.055.038 0 .058-.022.066-.055l.217-1.193-.217-1.228c-.008-.03-.028-.055-.058-.055zm1.83-1.507c-.059 0-.12.047-.12.1l-.21 2.335.21 2.226c0 .058.054.105.12.105.061 0 .113-.047.12-.105l.233-2.226-.233-2.335c-.007-.053-.059-.1-.12-.1zm.899-.253c-.064 0-.12.053-.12.105l-.198 2.588.198 2.443c0 .058.056.105.12.105.063 0 .116-.047.123-.105l.221-2.443-.221-2.588c-.007-.052-.06-.105-.123-.105zm.914-.076c-.072 0-.132.06-.132.133l-.185 2.664.185 2.519c0 .073.06.133.132.133.073 0 .133-.06.14-.133l.206-2.519-.206-2.664c-.007-.073-.067-.133-.14-.133zm.907-.085c-.08 0-.145.065-.145.145l-.172 2.749.172 2.566c0 .08.065.145.145.145.079 0 .144-.065.152-.145l.192-2.566-.192-2.749c-.008-.08-.073-.145-.152-.145z"/>
        </svg>
      )}
    </a>
  ))}
</div>
