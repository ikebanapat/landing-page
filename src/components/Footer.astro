---
import SocialLinks from './SocialLinks.astro';

const currentYear = new Date().getFullYear();
---
<footer class="py-16 border-t border-[var(--border)]">
    <div class="max-w-7xl mx-auto px-6">
        <div class="grid md:grid-cols-3 gap-12 mb-12">
            <div>
                <a href="#" class="font-display text-2xl font-bold tracking-tight inline-block mb-4">
                    IKEBANA<span class="text-[var(--accent)]">PAT</span>
                </a>
                <p class="text-[var(--muted)] text-sm mb-6">
                    Producción musical con identidad.<br/>
                    Cada canción, un estilo.<br/>
                    Cada estilo, una historia.
                </p>
                <SocialLinks />
            </div>
            <div>
                <h4 class="font-medium mb-4">Enlaces</h4>
                <ul class="space-y-2 text-sm text-[var(--muted)]">
                    <li><a href="#sobre" class="hover:text-[var(--accent)] transition-colors">Sobre</a></li>
                    <li><a href="#servicios" class="hover:text-[var(--accent)] transition-colors">Servicios</a></li>
                    <li><a href="#de-hoy" class="hover:text-[var(--accent)] transition-colors">DE HOY</a></li>
                    <li><a href="#contacto" class="hover:text-[var(--accent)] transition-colors">Contacto</a></li>
                </ul>
            </div>
            <div>
                <h4 class="font-medium mb-4">Contacto</h4>
                <ul class="space-y-2 text-sm text-[var(--muted)]">
                    <li>Rivas-Vaciamadrid, Madrid, España</li>
                    <li>info@ikebanapat.com</li>
                    <li>+34 605 454 260</li>
                </ul>
            </div>
        </div>
        <div class="text-center text-xs text-[var(--muted)] pt-8 border-t border-[var(--border)]">
            &copy; {currentYear} IKEBANA PAT. Todos los derechos reservados.
        </div>
    </div>
</footer>
