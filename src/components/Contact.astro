---
const contactInfo = [
    { icon: "location", title: "Ubicación", lines: ["Rivas-Vaciamadrid, Madrid, España"] },
    { icon: "email", title: "Email", lines: ["info@ikebanapat.com"] },
    { icon: "phone", title: "Teléfono", lines: ["+34 605 454 260"] }
];
---
<section id="contacto" class="py-32 relative">
    <div class="max-w-7xl mx-auto px-6">
        <div class="grid lg:grid-cols-2 gap-16">
            <div class="space-y-8">
                <div class="reveal">
                    <span class="inline-block text-[var(--accent)] text-sm uppercase tracking-[0.3em] font-medium mb-4">Contacto</span>
                    <h2 class="font-display text-4xl md:text-5xl font-bold mb-4">Hablemos</h2>
                    <p class="text-[var(--muted)] text-lg leading-relaxed">
                        Cuéntanos sobre tu proyecto, qué necesitas y cuál es tu visión. Respondemos en menos de 24 horas.
                    </p>
                </div>

                <div class="reveal reveal-delay-1 space-y-6">
                    {contactInfo.map(info => (
                        <div class="flex items-start gap-4">
                            <div class="w-12 h-12 rounded-lg bg-[var(--accent)]/10 flex items-center justify-center shrink-0">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.5">
                                    {info.icon === 'location' && <><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></>}
                                    {info.icon === 'email' && <><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></>}
                                    {info.icon === 'phone' && <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>}
                                </svg>
                            </div>
                            <div>
                                <h4 class="font-medium mb-1">{info.title}</h4>
                                {info.lines.map(line => <p class="text-[var(--muted)]">{line}</p>)}
                            </div>
                        </div>
                    ))}
                </div>
            </div>

            <div class="reveal">
                <form id="contactForm" class="bg-[var(--card)] border border-[var(--border)] rounded-lg p-8 space-y-6">
                    <div>
                        <label for="name" class="block text-sm font-medium mb-2">Nombre</label>
                        <input type="text" id="name" name="name" required class="form-input" placeholder="Tu nombre">
                    </div>
                    
                    <div>
                        <label for="email" class="block text-sm font-medium mb-2">Email</label>
                        <input type="email" id="email" name="email" required class="form-input" placeholder="tu@email.com">
                    </div>
                    
                    <div>
                        <label for="service" class="block text-sm font-medium mb-2">¿Qué necesitas?</label>
                        <select id="service" name="service" class="form-input">
                            <option value="">Selecciona una opción</option>
                            <option value="ritmos">Producción de Ritmos</option>
                            <option value="grabacion">Grabación de Canciones</option>
                            <option value="completa">Canción Completa</option>
                            <option value="otro">Otro / Consultar</option>
                        </select>
                    </div>

                    <div>
                        <label for="message" class="block text-sm font-medium mb-2">Cuéntanos sobre tu proyecto</label>
                        <textarea id="message" name="message" rows="4" class="form-input" placeholder="Describe tu proyecto, género, objetivos..."></textarea>
                    </div>
                    
                    <button type="submit" class="btn-primary w-full">Enviar Mensaje</button>
                </form>
            </div>
        </div>
    </div>
</section>
