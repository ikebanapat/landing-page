---
// Componente de navegación
---
<nav class="fixed top-0 left-0 right-0 z-50 bg-gradient-to-b from-black/80 to-transparent backdrop-blur-sm transition-all duration-300">
    <div class="max-w-7xl mx-auto px-6 py-4">
        <div class="flex items-center justify-between">
            <a href="#inicio" class="font-display text-2xl font-bold tracking-tight">
                IKEBANA<span class="text-[var(--accent)]">PAT</span>
            </a>

            <!-- Desktop Nav -->
            <div class="hidden md:flex items-center gap-8">
                <a href="#sobre" class="nav-link text-sm uppercase tracking-wider text-[var(--muted)] hover:text-[var(--fg)] relative group">
                    Sobre
                    <span class="absolute bottom-[-4px] left-0 w-0 h-px bg-[var(--accent)] transition-all group-hover:w-full"></span>
                </a>
                <a href="#servicios" class="nav-link text-sm uppercase tracking-wider text-[var(--muted)] hover:text-[var(--fg)] relative group">
                    Servicios
                    <span class="absolute bottom-[-4px] left-0 w-0 h-px bg-[var(--accent)] transition-all group-hover:w-full"></span>
                </a>
                <a href="#de-hoy" class="nav-link text-sm uppercase tracking-wider text-[var(--muted)] hover:text-[var(--fg)] relative group">
                    DE HOY
                    <span class="absolute bottom-[-4px] left-0 w-0 h-px bg-[var(--accent)] transition-all group-hover:w-full"></span>
                </a>
                <a href="#contacto" class="nav-link text-sm uppercase tracking-wider text-[var(--muted)] hover:text-[var(--fg)] relative group">
                    Contacto
                    <span class="absolute bottom-[-4px] left-0 w-0 h-px bg-[var(--accent)] transition-all group-hover:w-full"></span>
                </a>
                <a href="#contacto" class="btn-primary text-sm">Reservar</a>
            </div>

            <!-- Mobile Menu Button -->
            <button id="menuBtn" class="mobile-menu-btn md:hidden flex items-center gap-2 px-3 py-2 border border-[var(--border)] rounded-md text-[var(--muted)] backdrop-blur-sm hover:text-[var(--fg)] hover:border-[var(--accent)]/60 transition-all duration-200" aria-label="Abrir menú">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="3" y1="6" x2="21" y2="6"></line>
                    <line x1="3" y1="12" x2="21" y2="12"></line>
                    <line x1="3" y1="18" x2="21" y2="18"></line>
                </svg>
            </button>
        </div>
    </div>
</nav>

<!-- Mobile Menu Overlay -->
<div id="mobileMenu" class="mobile-menu fixed inset-0 z-[60] flex flex-col" aria-hidden="true">
    <!-- Top bar -->
    <div class="flex items-center justify-between px-6 py-5 border-b border-[var(--border)]">
        <a href="#inicio" class="font-display text-xl font-bold tracking-tight mobile-link">
            IKEBANA<span class="text-[var(--accent)]">PAT</span>
        </a>
        <button id="closeMenu" class="flex items-center gap-2 px-3 py-2 border border-[var(--border)] rounded-md text-[var(--muted)] hover:text-[var(--fg)] hover:border-[var(--accent)]/60 transition-all duration-200" aria-label="Cerrar menú">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
        </button>
    </div>

    <!-- Nav Links -->
    <div class="flex-1 flex flex-col justify-center px-8">
        <a href="#sobre" class="mobile-link mobile-nav-item group flex items-center gap-5 py-5 border-b border-[var(--border)]/40">
            <span class="text-xs text-[var(--accent)] font-mono tracking-wider">01</span>
            <span class="font-display text-4xl font-bold group-hover:text-[var(--accent)] transition-colors duration-200">Sobre</span>
            <svg class="ml-auto opacity-0 translate-x-[-8px] group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-200" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="#servicios" class="mobile-link mobile-nav-item group flex items-center gap-5 py-5 border-b border-[var(--border)]/40">
            <span class="text-xs text-[var(--accent)] font-mono tracking-wider">02</span>
            <span class="font-display text-4xl font-bold group-hover:text-[var(--accent)] transition-colors duration-200">Servicios</span>
            <svg class="ml-auto opacity-0 translate-x-[-8px] group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-200" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="#de-hoy" class="mobile-link mobile-nav-item group flex items-center gap-5 py-5 border-b border-[var(--border)]/40">
            <span class="text-xs text-[var(--accent)] font-mono tracking-wider">03</span>
            <span class="font-display text-4xl font-bold group-hover:text-[var(--accent)] transition-colors duration-200">DE HOY</span>
            <svg class="ml-auto opacity-0 translate-x-[-8px] group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-200" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="#contacto" class="mobile-link mobile-nav-item group flex items-center gap-5 py-5">
            <span class="text-xs text-[var(--accent)] font-mono tracking-wider">04</span>
            <span class="font-display text-4xl font-bold group-hover:text-[var(--accent)] transition-colors duration-200">Contacto</span>
            <svg class="ml-auto opacity-0 translate-x-[-8px] group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-200" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
    </div>

    <!-- Footer CTA -->
    <div class="px-8 pb-10 pt-6 border-t border-[var(--border)] space-y-3">
        <a href="#contacto" class="btn-primary w-full text-center block mobile-link text-base">
            Reservar Sesión
        </a>
        <p class="text-xs text-[var(--muted)] text-center tracking-wider uppercase">
            Producción musical con identidad
        </p>
    </div>
</div>

<style>
    .mobile-menu-btn {
        /* More transparent / blended with the navbar */
        background: color-mix(in srgb, var(--card) 12%, transparent);
        border-color: color-mix(in srgb, var(--border) 65%, transparent);
        -webkit-backdrop-filter: blur(8px);
    }

    .mobile-menu-btn:hover {
        background: color-mix(in srgb, var(--card) 18%, transparent);
    }

    /* Mobile overlay base */
    #mobileMenu {
        background: color-mix(in srgb, var(--bg) 72%, transparent);
        backdrop-filter: blur(26px) saturate(1.1);
        -webkit-backdrop-filter: blur(26px) saturate(1.1);
    }

    /* Stagger animation on links when menu opens */
    .mobile-nav-item {
        opacity: 0;
        transform: translateX(24px);
        transition:
            opacity 0.35s ease,
            transform 0.35s ease,
            color 0.2s ease;
    }

    .mobile-menu.open .mobile-nav-item:nth-child(1) {
        opacity: 1;
        transform: translateX(0);
        transition-delay: 0.12s;
    }
    .mobile-menu.open .mobile-nav-item:nth-child(2) {
        opacity: 1;
        transform: translateX(0);
        transition-delay: 0.19s;
    }
    .mobile-menu.open .mobile-nav-item:nth-child(3) {
        opacity: 1;
        transform: translateX(0);
        transition-delay: 0.26s;
    }
    .mobile-menu.open .mobile-nav-item:nth-child(4) {
        opacity: 1;
        transform: translateX(0);
        transition-delay: 0.33s;
    }
</style>

<script>
    const menuBtn = document.getElementById('menuBtn');
    const closeMenu = document.getElementById('closeMenu');
    const mobileMenu = document.getElementById('mobileMenu');

    function openMenu() {
        mobileMenu?.classList.add('open');
        mobileMenu?.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
    }

    function closeMenuFn() {
        mobileMenu?.classList.remove('open');
        mobileMenu?.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
    }

    menuBtn?.addEventListener('click', openMenu);
    closeMenu?.addEventListener('click', closeMenuFn);

    document.querySelectorAll('.mobile-link').forEach(link => {
        link.addEventListener('click', closeMenuFn);
    });

    // Cerrar con tecla Escape
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && mobileMenu?.classList.contains('open')) {
            closeMenuFn();
        }
    });

    // Navbar background change on scroll
    const nav = document.querySelector('nav');
    window.addEventListener('scroll', () => {
        if (nav) {
            if (window.scrollY > 100) {
                nav.style.background = 'rgba(8, 8, 10, 0.95)';
                nav.style.backdropFilter = 'blur(10px)';
            } else {
                nav.style.background = '';
                nav.style.backdropFilter = '';
            }
        }
    });
</script>
