---
const testimonials = [
    {
        name: "Luna Negra",
        role: "Artista",
        text: "Trabajar con Ikebana Pat fue transformar mi visión en realidad. Cada detalle tiene su razón de ser. El resultado suena a mí, pero mejorado mil veces.",
        rating: 5
    },
    {
        name: "MC Kairos",
        role: "Rapero/Productor",
        text: "Nunca había trabajado con alguien que entendiera tan bien la fusión de géneros. Sow ft era lo que buscaba hace tiempo.",
        rating: 5
    },
    {
        name: "Elena Voss",
        role: "Cantautora",
        text: "La sesión de grabación fue una experiencia única. Ikebana Pat sabe crear un ambiente donde te sientes cómodo para dar lo mejor de ti.",
        rating: 5
    }
];
---
<section id="testimonios" class="py-32 relative">
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[var(--accent)]/5 to-transparent pointer-events-none"></div>
    
    <div class="max-w-7xl mx-auto px-6 relative">
        <div class="text-center mb-20">
            <span class="reveal inline-block text-[var(--accent)] text-sm uppercase tracking-[0.3em] font-medium mb-4">Testimonios</span>
            <h2 class="reveal reveal-delay-1 font-display text-4xl md:text-6xl font-bold">Lo que dicen los artistas</h2>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
            {testimonials.map((testimonial, index) => (
                <div class="reveal testimonial-card p-8">
                    <div class="flex gap-1 mb-4">
                        {[...Array(testimonial.rating)].map(() => (
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="var(--accent)">
                                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                            </svg>
                        ))}
                    </div>
                    <p class="text-[var(--fg)] mb-6 leading-relaxed">"{testimonial.text}"</p>
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-full bg-[var(--accent)]/20 flex items-center justify-center">
                            <span class="font-display font-bold text-[var(--accent)]">{testimonial.name[0]}</span>
                        </div>
                        <div>
                            <p class="font-medium">{testimonial.name}</p>
                            <p class="text-xs text-[var(--muted)]">{testimonial.role}</p>
                        </div>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>
