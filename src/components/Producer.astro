---
import SocialLinks from './SocialLinks.astro';

const about = {
    title: "Sobre Ikebana Pat",
    philosophy: "Ikebana Pat nace del arte japonés del ikebana: la disciplina de unir elementos distintos para crear una composición con equilibrio y carácter propio.",
    approach: "Fusionando géneros urbanos y electrónicos —desde reggaeton, house y afro hasta synthwave y pop— cada producción se construye con una premisa clara: si no transmite, se transforma.",
    goal: "Más que seguir tendencias, el objetivo es encontrar la esencia de cada artista y convertirla en un sonido reconocible.",
};
---
<section id="sobre" class="py-32 relative overflow-hidden">

    <div class="max-w-7xl mx-auto px-6">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
            <div class="reveal relative order-2 lg:order-1">
                <div class="aspect-[3/4] bg-gradient-to-br from-[var(--card)] to-[var(--bg-elevated)] rounded-lg overflow-hidden border border-[var(--border)] relative">
                    <img src="/images/SLG00453.jpg" alt="Ikebana Pat - Productor Musical" class="w-full h-full object-cover">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
                </div>
            </div>

            <div class="space-y-8 order-1 lg:order-2">
                <div class="reveal">
                    <span class="inline-block text-[var(--accent)] text-sm uppercase tracking-[0.3em] font-medium mb-4">Sobre Mí</span>
                    <h2 class="font-display text-4xl md:text-5xl font-bold mb-6">Ikebana Pat</h2>
                </div>

                <div class="reveal reveal-delay-1 space-y-6">
                    <p class="text-[var(--fg)] text-lg leading-relaxed">
                        {about.philosophy}
                    </p>
                    <p class="text-[var(--muted)] leading-relaxed">
                        {about.approach}
                    </p>
                    <p class="text-[var(--muted)] leading-relaxed border-l-2 border-[var(--accent)] pl-4">
                        {about.goal}
                    </p>
                </div>
        <iframe data-testid="embed-iframe" style="border-radius:12px" src="https://open.spotify.com/embed/artist/6ENgRzOl5lyD4HavapJ99W?utm_source=generator&theme=0" width="100%" height="152" frameBorder="0" allowfullscreen="" allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" loading="lazy"></iframe>
                <div class="reveal reveal-delay-3">
                    <p class="text-sm text-[var(--muted)] mb-4">Sígueme en:</p>
                    <SocialLinks />
                </div>
            </div>
        </div>
    </div>
</section>
