---
const videoItems = [
    {
        id: "uO6FwQjGJ7w",
        title: "CUCU (feat Deri C)",
    },
    {
        id: "mv20lj3Z8a8",
        title: "COLORES (feat Capo ABT)",
    },
    {
        id: "o_jDxp9rtGo",
        title: "TOKYO (feat Capo ABT, Deri C, Ekaton)",
    },
    {
        id: "lwt4S19b-MM",
        title: "SANTUARIO (feat Ian Ice)",
    },
    {
        id: "lZK47n8uovc",
        title: "EN VELA (feat Tu Payaso Favorito)",
    },
    {   
        id: "_4WC2nGFsw4",
        title: "GOTHAM (feat Deri C, Ekaton)",
    },
    {
        id: "VZg7N_xIaRY",
        title: "NO LLORES (feat D.Nadie)",
    },
    {
        id: "N1eleT48xQY",
        title: "SI NO FALLAS (feat NZ, Deri C)",
    },
] as const;

const getThumb = (id: string) => `https://i.ytimg.com/vi/${id}/hqdefault.jpg`;

const getBentoSpan = (index: number) => {
    // Responsive bento layout: simple on mobile, featured + varied spans on larger screens
    // Grid columns: 1 (mobile), 2 (sm), 12 (lg)
    if (index === 0) return "sm:col-span-2 lg:col-span-7 lg:row-span-2";
    if (index === 1) return "lg:col-span-5 lg:row-span-1";
    if (index === 2) return "lg:col-span-5 lg:row-span-1";
    if (index === 3) return "lg:col-span-4 lg:row-span-1";
    if (index === 4) return "lg:col-span-4 lg:row-span-1";
    if (index === 5) return "lg:col-span-4 lg:row-span-1";
    if (index === 6) return "lg:col-span-6 lg:row-span-1";
    if (index === 7) return "lg:col-span-6 lg:row-span-1";
    return "sm:col-span-2 lg:col-span-12 lg:row-span-1";
};
---
<section id="de-hoy" class="py-32 relative">
    <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-20">
            <span class="reveal inline-block text-[var(--accent)] text-sm uppercase tracking-[0.3em] font-medium mb-4">Álbum</span>
            <h2 class="reveal reveal-delay-1 font-display text-4xl md:text-6xl font-bold">DE HOY</h2>
            <p class="reveal reveal-delay-2 text-[var(--muted)] mt-4 max-w-2xl mx-auto">
                Disponible en todas las plataformas
            </p>
        </div>
        <div class="bento-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-12 gap-6">
            {videoItems.map((item, index) => (
                <button
                    type="button"
                    class={`video-tile reveal group relative overflow-hidden rounded-lg text-left ${getBentoSpan(index)}`}
                    data-video-id={item.id}
                    aria-label={`Reproducir ${item.title}`}
                >
                    <img
                        src={getThumb(item.id)}
                        alt={item.title}
                        loading="lazy"
                        decoding="async"
                        class="video-thumb w-full h-full object-cover transition-transform duration-700"
                    />
                    <div class="video-overlay absolute inset-0 bg-gradient-to-t from-black/85 via-black/25 to-transparent opacity-90 group-hover:opacity-100 transition-opacity duration-300" aria-hidden="true"></div>

                    <div class="absolute inset-0 flex items-center justify-center" aria-hidden="true">
                        <span class="video-play">
                            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                <path d="M10 8.5v7l6-3.5-6-3.5Z" fill="currentColor" />
                                <path d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18Z" stroke="currentColor" stroke-width="1.5" />
                            </svg>
                        </span>
                    </div>

                    <div class="absolute inset-x-0 bottom-0 p-5 flex items-end justify-between gap-4">
                        <h3 class="font-display text-lg md:text-xl font-bold leading-tight">{item.title}</h3>
                    </div>
                </button>
            ))}
        </div>
    </div>

    <!-- Lightbox / modal de vídeo (se monta al hacer click) -->
    <div id="videoLightbox" class="video-lightbox" aria-hidden="true">
        <div class="video-dialog" role="dialog" aria-modal="true" aria-label="Reproductor de vídeo">
            <button id="closeVideo" type="button" class="video-close" aria-label="Cerrar vídeo" title="Cerrar">
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M18 6 6 18" />
                    <path d="M6 6l12 12" />
                </svg>
            </button>

            <div class="video-frame" style="aspect-ratio: 16 / 9;">
                <iframe
                    id="videoFrame"
                    title="Video"
                    class="absolute inset-0 w-full h-full"
                    src=""
                    allow="autoplay; encrypted-media; picture-in-picture"
                    allowfullscreen
                    referrerpolicy="strict-origin-when-cross-origin"
                ></iframe>
            </div>
        </div>
    </div>
</section>

<style>
    .bento-grid {
        /* Let tiles have height without relying on aspect ratios */
        grid-auto-rows: clamp(11rem, 20vw, 15rem);
    }

    .video-tile {
        border: 1px solid var(--border);
        background: color-mix(in srgb, var(--card) 25%, transparent);
        transition: transform 220ms ease, border-color 220ms ease, box-shadow 220ms ease;
        min-height: 12rem;
    }

    /* Some YouTube thumbnails include baked-in letterboxing (black bars).
       We crop it by applying a baseline zoom so bars are pushed outside the tile. */
    .video-thumb {
        transform: scale(1.085);
        will-change: transform;
    }

    .video-tile:hover .video-thumb {
        transform: scale(1.145);
    }

    @media (min-width: 1024px) {
        .video-tile { min-height: auto; }
    }

    .video-tile:hover {
        transform: translateY(-2px);
        border-color: color-mix(in srgb, var(--accent) 35%, var(--border));
        box-shadow: 0 18px 60px rgba(0, 0, 0, 0.45);
    }

    .video-tile:focus-visible {
        outline: none;
        box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 35%, transparent);
    }

    /* Featured tile: a touch more presence */
    .video-tile.sm\:col-span-2 {
        /* noop on purpose: keeps selector stable if you tweak spans */
    }

    .video-play {
        width: 3.25rem;
        height: 3.25rem;
        border-radius: 9999px;
        display: grid;
        place-items: center;
        border: 1px solid color-mix(in srgb, var(--border) 75%, transparent);
        background: color-mix(in srgb, var(--card) 30%, transparent);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        color: var(--fg);
        transform: scale(0.98);
        transition: transform 180ms ease, background 180ms ease, border-color 180ms ease, color 180ms ease, opacity 180ms ease;
        opacity: 0.98;
    }
    .video-tile:hover .video-play {
        transform: scale(1.06);
        border-color: color-mix(in srgb, var(--accent) 55%, transparent);
        color: var(--accent);
        background: color-mix(in srgb, var(--card) 45%, transparent);
        opacity: 1;
    }
    .video-play svg { width: 2.1rem; height: 2.1rem; }

    .video-tile:hover .video-thumb {
        filter: saturate(1.05) contrast(1.05);
    }

    .video-lightbox {
        position: fixed;
        inset: 0;
        z-index: 80;
        display: none;
        padding: clamp(1rem, 4vw, 2rem);
        background: color-mix(in srgb, var(--bg) 65%, transparent);
        backdrop-filter: blur(22px) saturate(1.05);
        -webkit-backdrop-filter: blur(22px) saturate(1.05);
        align-items: center;
        justify-content: center;
    }
    .video-lightbox.is-open { display: flex; }

    .video-dialog {
        width: min(72rem, 100%);
        position: relative;
    }

    .video-frame {
        position: relative;
        width: 100%;
        border-radius: 0.75rem;
        overflow: hidden;
        border: 1px solid var(--border);
        background: #000;
        box-shadow: 0 30px 90px rgba(0, 0, 0, 0.55);
    }

    .video-close {
        position: absolute;
        top: calc(0rem - 0.5rem);
        right: calc(0rem - 0.5rem);
        width: 2.75rem;
        height: 2.75rem;
        border-radius: 9999px;
        border: 1px solid var(--border);
        background: color-mix(in srgb, var(--card) 55%, transparent);
        color: var(--fg);
        display: grid;
        place-items: center;
        cursor: pointer;
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        transition: background 180ms ease, border-color 180ms ease, color 180ms ease, transform 180ms ease;
    }

    .video-close:hover {
        border-color: var(--accent);
        color: var(--accent);
        background: color-mix(in srgb, var(--card) 85%, transparent);
        transform: translateY(-1px);
    }

    .video-close:focus-visible {
        outline: none;
        box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 35%, transparent);
    }

    .video-close svg {
        width: 1.25rem;
        height: 1.25rem;
    }
    .video-close path {
        stroke: currentColor;
        stroke-width: 2;
        stroke-linecap: round;
    }
</style>

<script>
    const modal = document.getElementById('videoLightbox');
    const frame = document.getElementById('videoFrame');
    const closeBtn = document.getElementById('closeVideo');
    const triggers = document.querySelectorAll('[data-video-id]');

    const buildEmbedSrc = (id) => {
        const params = new URLSearchParams({
            autoplay: '1',
            mute: '0',
            playsinline: '1',
            rel: '0',
            modestbranding: '1',
        });
        return `https://www.youtube-nocookie.com/embed/${id}?${params.toString()}`;
    };

    const openVideo = (id) => {
        if (!modal || !frame) return;
        frame.src = buildEmbedSrc(id);
        modal.classList.add('is-open');
        modal.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
        closeBtn?.focus();
    };

    const closeVideo = () => {
        if (!modal || !frame) return;
        modal.classList.remove('is-open');
        modal.setAttribute('aria-hidden', 'true');
        frame.src = '';
        document.body.style.overflow = '';
    };

    triggers.forEach((el) => {
        el.addEventListener('click', () => {
            const id = el.getAttribute('data-video-id');
            if (id) openVideo(id);
        });
    });

    closeBtn?.addEventListener('click', closeVideo);

    modal?.addEventListener('click', (e) => {
        if (e.target === modal) closeVideo();
    });

    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && modal?.classList.contains('is-open')) {
            closeVideo();
        }
    });
</script>
